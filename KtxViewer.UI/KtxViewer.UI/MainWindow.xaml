<Window x:Class="KtxViewer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="KTX2 Viewer" Height="700" Width="1000"
        Icon="icon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="60"
                           ResizeBorderThickness="5"
                           CornerRadius="0"
                           GlassFrameThickness="0"
                           UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" CornerRadius="12" Background="#E0101010" BorderBrush="#40FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#20FFFFFF" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="KTX2 Viewer"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Light"
                               VerticalAlignment="Center"
                               Margin="20,0,0,0"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <Button Content="min"
                                Click="Minimize_Click"
                                Width="60" Height="30"
                                Style="{StaticResource GlassButton}"
                                Margin="5,0"
                                FontSize="13"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="max"
                                Click="Maximize_Click"
                                Width="60" Height="30"
                                Style="{StaticResource GlassButton}"
                                Margin="5,0"
                                FontSize="13"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="close"
                                Click="Close_Click"
                                Width="70" Height="30"
                                Style="{StaticResource GlassButton}"
                                Margin="5,0"
                                FontSize="13"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Border Background="#10FFFFFF" CornerRadius="8" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding CurrentImage, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="No texture loaded"
                                       Foreground="#80FFFFFF"
                                       FontSize="24"
                                       FontWeight="Light"
                                       HorizontalAlignment="Center"/>
                            <Button Content="Open KTX2 File"
                                    Style="{StaticResource GlassButton}"
                                    Command="{Binding OpenFileCommand}"
                                    Margin="0,20,0,0"
                                    FontSize="16"
                                    Padding="24,12"/>
                        </StackPanel>

                        <ScrollViewer x:Name="ImageScrollViewer"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                                     PreviewMouseLeftButtonDown="ScrollViewer_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="ScrollViewer_PreviewMouseMove"
                                     PreviewMouseLeftButtonUp="ScrollViewer_PreviewMouseLeftButtonUp"
                                     Background="Transparent"
                                     IsHitTestVisible="{Binding CurrentImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                            <Image x:Name="ZoomImage"
                                   Source="{Binding CurrentImage}"
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                                <Image.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding ZoomLevel}"
                                                   ScaleY="{Binding ZoomLevel}"/>
                                </Image.LayoutTransform>
                            </Image>
                        </ScrollViewer>

                        <Border Background="#80000000"
                                CornerRadius="8"
                                Padding="12,6"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="10">
                            <TextBlock Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold">
                                <Run Text="{Binding ZoomLevel, StringFormat={}{0:P0}, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#20FFFFFF" Height="50" CornerRadius="0,0,12,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <Button Content="Open File"
                                Style="{StaticResource GlassButton}"
                                Command="{Binding OpenFileCommand}"/>

                        <Button Content="Reset Zoom"
                                Style="{StaticResource GlassButton}"
                                Command="{Binding ResetZoomCommand}"
                                Margin="10,0,0,0"/>

                        <StackPanel Orientation="Vertical" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FileInfo}"
                                       Foreground="#CCFFFFFF"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ImageInfo}"
                                       Foreground="#99FFFFFF"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <ProgressBar IsIndeterminate="True"
                                 Height="4"
                                 VerticalAlignment="Bottom"
                                 Background="Transparent"
                                 Foreground="#60FFFFFF"
                                 BorderThickness="0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
