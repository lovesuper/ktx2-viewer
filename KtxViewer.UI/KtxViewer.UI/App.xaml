<Application x:Class="KtxViewer.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KtxViewer.UI"
             xmlns:converters="clr-namespace:KtxViewer.UI.Converters">
    <Application.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToThicknessConverter x:Key="BoolToThicknessConverter"/>
        <converters:FileNameConverter x:Key="FileNameConverter"/>
        <converters:SubtractConverter x:Key="SubtractConverter"/>
        <converters:IndexToNumberConverter x:Key="IndexToNumberConverter"/>
        <converters:InverseScaleConverter x:Key="InverseScaleConverter"/>

        <!-- ====================================================================
             Liquid Glass design tokens.
             Glass is the FUNCTIONAL layer (bars, panels, controls) that floats
             above the content. Surfaces use a light-catching top-to-bottom
             gradient (lensing), a hairline rgba border and a specular top
             highlight; floating panels add a soft shadow for depth. Translucency
             is kept readable, never flat or fully opaque.
             ==================================================================== -->

        <!-- Interactive control (button) surfaces -->
        <LinearGradientBrush x:Key="GlassControlBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#33FFFFFF" Offset="0"/>
            <GradientStop Color="#1AFFFFFF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassControlHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4DFFFFFF" Offset="0"/>
            <GradientStop Color="#2BFFFFFF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassControlPressedBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#16FFFFFF" Offset="0"/>
            <GradientStop Color="#0FFFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Toolbars / chrome bars (subtle, recede behind content) -->
        <LinearGradientBrush x:Key="GlassBarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#26FFFFFF" Offset="0"/>
            <GradientStop Color="#14FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Floating panels (info, file list) - dark tinted glass, kept legible -->
        <LinearGradientBrush x:Key="GlassPanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D81E2630" Offset="0"/>
            <GradientStop Color="#CC141A22" Offset="1"/>
        </LinearGradientBrush>

        <!-- Small floating overlays (badges, nav) -->
        <LinearGradientBrush x:Key="GlassOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B0222A34" Offset="0"/>
            <GradientStop Color="#A0141A22" Offset="1"/>
        </LinearGradientBrush>

        <!-- Hairline edge + specular top highlight (lensing) -->
        <SolidColorBrush x:Key="GlassBorderBrush" Color="#4DFFFFFF"/>
        <LinearGradientBrush x:Key="GlassHighlightBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3CFFFFFF" Offset="0"/>
            <GradientStop Color="#0AFFFFFF" Offset="0.5"/>
            <GradientStop Color="#00FFFFFF" Offset="0.5"/>
        </LinearGradientBrush>

        <!-- Soft shadow that lifts a glass surface above the content layer -->
        <DropShadowEffect x:Key="GlassDepthShadow" Color="#000000" ShadowDepth="0" BlurRadius="24" Opacity="0.45"/>

        <!-- ====================================================================
             Dark slim scrollbars. WPF's default ScrollBar theme is light/grey,
             which looks white on the dark UI (most visible on Windows 10). This
             restyles every ScrollBar (image viewer, file list, metadata) to match.
             ==================================================================== -->
        <Style x:Key="GlassScrollPageButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassScrollThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbBorder" CornerRadius="4" Margin="2" Background="#59FFFFFF"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#8CFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#B3FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource GlassScrollPageButton}" Command="{x:Static ScrollBar.PageUpCommand}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource GlassScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource GlassScrollPageButton}" Command="{x:Static ScrollBar.PageDownCommand}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="11"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollViewer with a dark corner (the default corner is a white square
             where the vertical and horizontal scrollbars meet). -->
        <Style x:Key="GlassScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Row="0" Grid.Column="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    CanHorizontallyScroll="False"
                                                    CanVerticallyScroll="False"/>

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Row="0" Grid.Column="1"
                                       Orientation="Vertical"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Cursor="Arrow"/>

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1" Grid.Column="0"
                                       Orientation="Horizontal"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Cursor="Arrow"/>

                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="Transparent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
